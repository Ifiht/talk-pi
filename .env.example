# Pi-listener configuration
# Copy to .env (gitignored) and set your private wake word.

# Wake word — REQUIRED. The name that activates the hands-free loop.
# Keep your real value only in .env, never commit it.
PI_LISTENER_ACTIVATION_NAME=assistant

# Listener binary (default: ./native/listener/build/pi-listener; run native/listener/build.sh)
PI_LISTENER_BIN=
# Confirmation chime WAV (default: ./sound/QuestLog.wav)
PI_LISTENER_CHIME=
# Extra args passed through to the listener binary, e.g. "-vth 0.7 -c 1 -fms 10000"
PI_LISTENER_ARGS=

# Piper TTS
# Optional override if tools live elsewhere
PI_LISTENER_TOOLS_DIR=
PI_LISTENER_PIPER_BIN=
PI_LISTENER_PIPER_MODEL_PATH=
# Leave empty to use the default temp directory
PI_LISTENER_TTS_OUTPUT_DIR=

# Whisper wake-word model
PI_LISTENER_WHISPER_MODEL_PATH=
PI_LISTENER_WHISPER_MODEL_URL=https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin
